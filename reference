{% unless page.handle == 'iug-feedback' or page.handle == 'iug-feedback-new' %}
<!-- =========================
     SIDE FEEDBACK
========================= -->
<div id="vc-feedback-wrap">
  <button id="vc-side-close" type="button" aria-label="Close">?</button>

  <div id="vc-feedback-side">
    <div class="vc-side-title">Helpful?</div>

    <button class="vc-side-btn yes" type="button" aria-label="Yes, this page was helpful">
      <span class="vc-icon">??</span>
      <span class="vc-text">Yes</span>
    </button>

    <button class="vc-side-btn no" type="button" aria-label="No, this page was not helpful">
      <span class="vc-icon">??</span>
      <span class="vc-text">No</span>
    </button>
  </div>
</div>

<!-- =========================
     MODAL OVERLAY
========================= -->
<div class="vc-modal-overlay" style="display:none;">
  <div class="vc-modal" role="dialog" aria-modal="true" aria-labelledby="vc-modal-title">

    <div class="vc-close-wrap">
      <button id="vc-modal-close" type="button" aria-label="Close">?</button>
    </div>

    <div class="vc-card">

      <div class="vc-title" id="vc-modal-title">Was this page helpful?</div>

      <div class="vc-btns">
        <button class="vc-btn vc-yes" type="button">?? Yes</button>
        <button class="vc-btn vc-no" type="button">?? No</button>
      </div>

      <div class="vc-follow" style="display:none;">

        <div class="vc-subtitle">What was missing?</div>

        <div class="vc-options">

          <label class="vc-opt">
            <input type="checkbox" value="Hard to understand">
            <span>Hard to understand</span>
          </label>

          <label class="vc-opt">
            <input type="checkbox" value="Missing compatibility info">
            <span>Missing compatibility info</span>
          </label>

          <label class="vc-opt">
            <input type="checkbox" value="Too long / confusing">
            <span>Too long / confusing</span>
          </label>

          <label class="vc-opt">
            <input type="checkbox" value="I still have questions">
            <span>I still have questions</span>
          </label>

          <label class="vc-opt">
            <input class="vc-other-check" type="checkbox" value="Other">
            <span>Other</span>
          </label>

          <div class="vc-other-box" style="display:none;">
            <input
              type="text"
              class="vc-other-text"
              maxlength="160"
              placeholder="Optional: tell us what you were looking for (max 160 chars)"
            >
          </div>

        </div>

        <div class="vc-contact">
          <div class="vc-contact-title">Want us to help?</div>
          <input type="email" class="vc-email-input" placeholder="Email (optional)">
          <div class="vc-email-hint">Please leave your email if you'd like us to follow up.</div>
        </div>

        <button class="vc-submit" type="button" disabled>Submit</button>

        <div class="vc-hint">No login. No email unless you choose to leave one.</div>
      </div>

      <div class="vc-toast" style="display:none;">
        ? Thanks! Your feedback was submitted successfully.
      </div>

    </div>
  </div>
</div>

<!-- =========================
     SCRIPT
========================= -->
<script>
(function () {
  const ENDPOINT = "https://formspree.io/f/xqarjjkv";
  const PAGE_KEY = "vc_feedback_submitted_" + location.pathname;
  const CLOSE_KEY = "vc_feedback_closed_" + location.pathname;

  const overlay = document.querySelector(".vc-modal-overlay");
  const closeBtn = document.getElementById("vc-modal-close");
  const modal = document.querySelector(".vc-modal");

  if (!overlay || !closeBtn || !modal) return;

  const yesBtn = modal.querySelector(".vc-yes");
  const noBtn = modal.querySelector(".vc-no");
  const follow = modal.querySelector(".vc-follow");
  const submit = modal.querySelector(".vc-submit");
  const toast = modal.querySelector(".vc-toast");

  const otherCheck = modal.querySelector(".vc-other-check");
  const otherBox = modal.querySelector(".vc-other-box");
  const otherText = modal.querySelector(".vc-other-text");
  const emailInput = modal.querySelector(".vc-email-input");

  const sideWrap = document.getElementById("vc-feedback-wrap");
  const sideWidget = document.getElementById("vc-feedback-side");
  const sideClose = document.getElementById("vc-side-close");
  const sideYes = document.querySelector(".vc-side-btn.yes");
  const sideNo = document.querySelector(".vc-side-btn.no");

  let vote = null;
  let isSubmitting = false;

  function hideSideWidget() {
    if (sideWrap) {
      sideWrap.style.display = "none";
    }
  }

  function initSubmittedState() {
    if (
      sessionStorage.getItem(PAGE_KEY) === "1" ||
      sessionStorage.getItem(CLOSE_KEY) === "1"
    ) {
      hideSideWidget();
    }
  }

  function resetModalState() {
    vote = null;
    yesBtn.classList.remove("vc-selected");
    noBtn.classList.remove("vc-selected");
    follow.style.display = "none";
    toast.style.display = "none";
    submit.disabled = true;

    modal.querySelectorAll(".vc-opt input").forEach((cb) => {
      cb.checked = false;
      syncRow(cb);
    });

    otherBox.style.display = "none";
    otherText.value = "";
    emailInput.value = "";
  }

  function openModal() {
    overlay.style.display = "flex";
    overlay.scrollTop = 0;
    modal.scrollTop = 0;
  }

  function closeModal() {
    overlay.style.display = "none";
  }

  function select(btn) {
    yesBtn.classList.remove("vc-selected");
    noBtn.classList.remove("vc-selected");
    btn.classList.add("vc-selected");
  }

  function syncRow(cb) {
    const row = cb.closest(".vc-opt");
    if (row) {
      row.classList.toggle("vc-selected", cb.checked);
    }
  }

  function updateSubmit() {
    if (isSubmitting) {
      submit.disabled = true;
      return;
    }
    const checked = modal.querySelectorAll(".vc-opt input:checked").length > 0;
    submit.disabled = !(vote === "no" && checked);
  }

  async function send(data) {
    if (isSubmitting) return false;
    isSubmitting = true;

    yesBtn.disabled = true;
    noBtn.disabled = true;
    submit.disabled = true;
    if (sideYes) sideYes.disabled = true;
    if (sideNo) sideNo.disabled = true;
    if (sideClose) sideClose.disabled = true;

    const payload = {
      subject: "Venucast Page Feedback",
      vote: data.vote,
      reasons: data.reasons,
      other_text: data.other_text,
      email: data.email,
      page_title: document.title,
      page_url: location.href.split("#")[0],
      ts: new Date().toISOString()
    };

    try {
      const res = await fetch(ENDPOINT, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        body: JSON.stringify(payload)
      });

      if (!res.ok) throw new Error("Request failed");

      sessionStorage.setItem(PAGE_KEY, "1");
      return true;
    } catch (e) {
      alert("Submission failed. Please try again.");
      yesBtn.disabled = false;
      noBtn.disabled = false;
      if (sideYes) sideYes.disabled = false;
      if (sideNo) sideNo.disabled = false;
      if (sideClose) sideClose.disabled = false;
      updateSubmit();
      return false;
    } finally {
      isSubmitting = false;
    }
  }

  initSubmittedState();

  closeBtn.addEventListener("click", closeModal);

  overlay.addEventListener("click", function (e) {
    if (e.target === overlay) {
      closeModal();
    }
  });

  if (sideClose) {
    sideClose.addEventListener("click", function () {
      if (isSubmitting) return;
      sessionStorage.setItem(CLOSE_KEY, "1");
      hideSideWidget();
    });
  }

  modal.querySelectorAll(".vc-opt input").forEach((cb) => {
    syncRow(cb);
    cb.addEventListener("change", function () {
      syncRow(cb);
      updateSubmit();
    });
  });

  otherCheck.addEventListener("change", function () {
    otherBox.style.display = otherCheck.checked ? "block" : "none";
    if (!otherCheck.checked) {
      otherText.value = "";
    }
    updateSubmit();
  });

  otherText.addEventListener("input", updateSubmit);

  if (sideYes) {
    sideYes.addEventListener("click", async function () {
      if (
        sessionStorage.getItem(PAGE_KEY) === "1" ||
        sessionStorage.getItem(CLOSE_KEY) === "1" ||
        isSubmitting
      ) return;

      vote = "yes";

      sideYes.classList.add("vc-selected");
      sideYes.innerHTML = '<span class="vc-check">?</span>';
      if (sideNo) sideNo.style.opacity = "0.45";

      const ok = await send({
        vote: "yes",
        reasons: [],
        other_text: "",
        email: ""
      });

      if (ok) {
        setTimeout(function () {
          hideSideWidget();
        }, 800);
      } else {
        sideYes.classList.remove("vc-selected");
        sideYes.innerHTML = '<span class="vc-icon">??</span><span class="vc-text">Yes</span>';
        if (sideNo) sideNo.style.opacity = "";
      }
    });
  }

  if (sideNo) {
    sideNo.addEventListener("click", function () {
      if (
        sessionStorage.getItem(PAGE_KEY) === "1" ||
        sessionStorage.getItem(CLOSE_KEY) === "1" ||
        isSubmitting
      ) return;

      resetModalState();
      openModal();

      vote = "no";
      select(noBtn);
      follow.style.display = "block";
      updateSubmit();
    });
  }

  yesBtn.addEventListener("click", async function () {
    if (isSubmitting) return;

    vote = "yes";
    select(yesBtn);

    const ok = await send({
      vote: "yes",
      reasons: [],
      other_text: "",
      email: (emailInput.value || "").trim()
    });

    if (ok) {
      toast.style.display = "block";
      follow.style.display = "none";
      setTimeout(function () {
        closeModal();
        hideSideWidget();
      }, 1200);
    }
  });

  noBtn.addEventListener("click", function () {
    if (isSubmitting) return;

    vote = "no";
    select(noBtn);
    follow.style.display = "block";
    updateSubmit();
  });

  submit.addEventListener("click", async function () {
    if (isSubmitting) return;

    const reasons = Array.from(modal.querySelectorAll(".vc-opt input:checked")).map(function (x) {
      return x.value;
    });

    const other_text = reasons.includes("Other")
      ? (otherText.value || "").trim()
      : "";

    const email = (emailInput.value || "").trim();

    const ok = await send({
      vote: "no",
      reasons: reasons,
      other_text: other_text,
      email: email
    });

    if (ok) {
      toast.style.display = "block";
      follow.style.display = "none";
      setTimeout(function () {
        closeModal();
        hideSideWidget();
      }, 1200);
    }
  });
})();
</script>

